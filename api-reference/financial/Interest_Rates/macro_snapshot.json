{
  "openapi": "3.0.3",
  "info": {
    "title": "Interest Rates Snapshot",
    "version": "1.0.0",
    "description": "The Interest Rates Snapshot API returns the latest published interest rate data for major central banks around the world. Source: official monetary policy announcements."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/proxy_apis/v1/financial",
      "description": "Production API"
    }
  ],
  "paths": {
    "/macro/interest-rates/snapshot": {
      "get": {
        "summary": "Get latest interest rate data snapshot",
        "description": "Retrieve the most recent published interest rate data from central banks worldwide.",
        "tags": ["Macro", "Interest Rates"],
        "parameters": [],
        "responses": {
          "200": {
            "description": "Successful response with interest rate snapshot data",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "interest_rates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "bank": {
                            "type": "string",
                            "description": "The central bank identifier."
                          },
                          "name": {
                            "type": "string",
                            "description": "The central bank full name."
                          },
                          "rate": {
                            "type": "number",
                            "description": "The published interest rate."
                          },
                          "date": {
                            "type": "string",
                            "format": "date",
                            "description": "Publication date of the interest rate (YYYY-MM-DD)."
                          }
                        },
                        "required": ["bank", "name", "rate", "date"]
                      }
                    }
                  },
                  "required": ["interest_rates"]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request – missing parameters or invalid request"
          },
          "401": {
            "description": "Unauthorized – invalid or missing API key"
          },
          "402": {
            "description": "Payment Required – quota exceeded or billing issue"
          },
          "404": {
            "description": "Not Found – endpoint does not exist"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    },
    "/macro/interest-rates": {
      "get": {
        "summary": "Get historical interest rates",
        "description": "Retrieve historical interest rate data for a specified central bank over an optional date range.",
        "tags": ["Macro", "Interest Rates"],
        "parameters": [
          {
            "name": "bank",
            "in": "query",
            "description": "Central bank whose historical rates to return (use the banks endpoint to list valid codes).",
            "required": true,
            "schema": { "type": "string" }
          },
          {
            "name": "start_date",
            "in": "query",
            "description": "Start date for historical rates (YYYY-MM-DD).",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          },
          {
            "name": "end_date",
            "in": "query",
            "description": "End date for historical rates (YYYY-MM-DD).",
            "required": false,
            "schema": { "type": "string", "format": "date" }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with historical interest rates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "interest_rates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "bank": {
                            "type": "string",
                            "description": "Central bank identifier"
                          },
                          "name": {
                            "type": "string",
                            "description": "Central bank full name"
                          },
                          "rate": {
                            "type": "number",
                            "description": "Interest rate"
                          },
                          "date": {
                            "type": "string",
                            "format": "date",
                            "description": "Date of the rate"
                          }
                        },
                        "required": ["bank", "name", "rate", "date"]
                      }
                    }
                  },
                  "required": ["interest_rates"]
                }
              }
            }
          },
          "400": { "description": "Bad Request — missing bank or invalid dates" },
          "401": { "description": "Unauthorized — missing or invalid API key" },
          "402": { "description": "Payment Required" },
          "404": { "description": "Not Found" }
        },
        "security": [{ "bearerAuth": [] }]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  }
}
