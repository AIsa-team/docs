{
  "openapi": "3.0.3",
  "info": {
    "title": "Financial Datasets API \u2013 Analyst Estimates (Earnings Per Share)",
    "version": "1.0.0",
    "description": "Get analyst earnings per share estimates for a given ticker. This endpoint returns probabilistic forecast estimates."
  },
  "servers": [
    {
      "url": "https://api.aisa.one/apis/v1/financial",
      "description": "Production API"
    }
  ],
  "paths": {
    "/analyst-estimates": {
      "get": {
        "summary": "Get Analyst Estimates by Ticker",
        "description": "Fetch earnings per share estimates for a specified stock ticker and period.",
        "tags": [
          "Analyst Estimates"
        ],
        "parameters": [
          {
            "name": "ticker",
            "in": "query",
            "description": "Stock ticker to get analyst estimates for",
            "required": true,
            "schema": {
              "type": "string"
            }
          },
          {
            "name": "period",
            "in": "query",
            "description": "The period type ('annual' or 'quarterly'). Defaults to 'annual'.",
            "required": false,
            "schema": {
              "type": "string",
              "enum": [
                "annual",
                "quarterly"
              ],
              "default": "annual"
            }
          }
        ],
        "responses": {
          "200": {
            "description": "Successful response with analyst estimates",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "analyst_estimates": {
                      "type": "array",
                      "items": {
                        "type": "object",
                        "properties": {
                          "fiscal_period": {
                            "type": "string",
                            "description": "The fiscal period for the estimate"
                          },
                          "period": {
                            "type": "string",
                            "description": "The period type (annual or quarterly)"
                          },
                          "earnings_per_share": {
                            "type": "number",
                            "format": "float",
                            "description": "Estimated earnings per share"
                          }
                        },
                        "required": [
                          "fiscal_period",
                          "period",
                          "earnings_per_share"
                        ]
                      }
                    }
                  },
                  "required": [
                    "analyst_estimates"
                  ]
                }
              }
            }
          },
          "400": {
            "description": "Bad Request"
          },
          "401": {
            "description": "Unauthorized \u2013 missing or invalid API key"
          },
          "404": {
            "description": "Not Found"
          }
        },
        "security": [
          {
            "bearerAuth": []
          }
        ]
      }
    }
  },
  "components": {
    "securitySchemes": {
      "bearerAuth": {
        "type": "http",
        "scheme": "bearer"
      }
    }
  },
  "security": [
    {
      "bearerAuth": []
    }
  ]
}